# Copy to `.env` at the repository root. Values are read by the FastAPI app (AURALIA_*)
# and the Vite dev server (VITE_*).

# --- Backend (Pydantic Settings, prefix AURALIA_) ---
AURALIA_API_HOST=0.0.0.0
AURALIA_API_PORT=8000
AURALIA_SQLITE_PATH=data/db/auralia.sqlite
# Comma-separated browser origins allowed for CORS during local dev
# (TanStack Start CLI defaults the web app to port 3000; include both if you use either.)
AURALIA_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend (Vite: only VITE_* are exposed to the browser) ---
# Leave empty to use same-origin requests (recommended with Vite proxy in dev).
# Example for a remote API: VITE_API_URL=http://127.0.0.1:8000
VITE_API_URL=
